# MedCloud API Gateway URL
# Production (US): https://fm2l2133of.execute-api.us-east-1.amazonaws.com/prod
# MUST be set in Vercel Environment Variables (Production + Preview + Development)
# Local dev: copy this file to .env.local and set your URL
NEXT_PUBLIC_API_URL=https://fm2l2133of.execute-api.us-east-1.amazonaws.com/prod

# Cognito Auth (server-side only — never exposed to browser)
# Set all four in Vercel Environment Variables → All Environments
COGNITO_CLIENT_ID=your-app-client-id
COGNITO_CLIENT_SECRET=your-app-client-secret
AWS_COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
